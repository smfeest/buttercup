@inject IViewLocalizer Localizer
@model Buttercup.Web.Models.Recipes.EditRecipeViewModel
@{
  ViewData["Title"] = Localizer["Title_EditRecipe", Model!.Attributes.Title];
}
<h1>@Localizer["Heading_EditRecipe"]</h1>
<form method="post" enctype="multipart/form-data">
  @Html.EditorFor(m => m.Attributes)
  <input type="hidden" asp-for="BaseRevision">
  <input type="hidden" asp-for="ExistingPhotoUrl">
  <div class="form-group">
    <label asp-for="Photo">@Localizer["Label_Photo"]</label>
    @if (!string.IsNullOrEmpty(Model.ExistingPhotoUrl))
    {
      <div class="existing-photo">
        <img src="@Model.ExistingPhotoUrl" alt="@Localizer["Alt_CurrentPhoto"]" style="max-width: 300px; max-height: 300px; display: block; margin-bottom: 10px;" />
      </div>
    }
    <input type="file" asp-for="Photo" accept="image/*" />
  </div>
  <div class="button-bar">
    <button class="primary-push-button">@Localizer["Label_Save"]</button>
    <a class="push-button" asp-action="Show" asp-route-id="@Model.Id">@Localizer["Label_Cancel"]</a>
  </div>
</form>
